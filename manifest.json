{
  "manifest_version": 3,
  "name": "Chronos: Productivity Tracker",
  "version": "1.0",
  "permissions": ["tabs", "idle", "storage"],
  "host_permissions": [
    "http://127.0.0.1:8000/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module" 
  },
  "action": {
    "default_popup": "popup.html"
  }
}